{
  "name": "arrow-flight-client",
  "version": "0.0.8",
  "description": "Apache Arrow Flight Client for Node.js",
  "keywords": [
    "apache-arrow",
    "arrow-flight",
    "arrow-ipc",
    "flight-rpc",
    "grpc",
    "protobuf",
    "record-batch",
    "columnar-data"
  ],
  "author": {
    "name": "Stanislav Potemkin",
    "email": "woodger@ya.ru"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woodger/arrow-flight-client.git"
  },
  "engines": {
    "node": ">=16.9.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./raw": {
      "types": "./dist/raw.d.ts",
      "require": "./dist/raw.js",
      "default": "./dist/raw.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "tsc",
    "test": "fwa --prune",
    "test:pyarrow": "node --test dist/client/flight-client.pyarrow.e2e.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@grpc/grpc-js": "^1.14.4",
    "apache-arrow": "^21.1.0",
    "nice-grpc": "^2.1.16",
    "nice-grpc-common": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.1",
    "eslint": "^9.39.4",
    "fwa": "^2.0.6",
    "globals": "^17.7.0",
    "grpc-tools": "^1.13.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
